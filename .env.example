# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: master passphrase for DB encryption and field-level Fernet encryption.
GITDR_DB_PASSPHRASE=change-me-to-a-strong-random-passphrase

# Optional overrides (defaults shown):
# GITDR_DB_PATH=./data/gitdr.db
# GITDR_CACHE_DIR=./data/mirror-cache
# GITDR_TEMP_DIR=./data/tmp
# GITDR_HOST=0.0.0.0
# GITDR_PORT=8420
# GITDR_LOG_LEVEL=INFO
# GITDR_WORKERS=1
